{
  "@context": "https://standard.site/",
  "@id": "https://octothorp.es/publishers/atproto.document",
  "@type": "resolver",
  "meta": {
    "name": "ATProto Document",
    "description": "Converts blobjects to site.standard.document format for AT Protocol publishing platforms",
    "lexicon": "site.standard.document",
    "version": "1.0"
  },
  "schema": {
    "url": {
      "from": "@id",
      "required": true
    },
    "title": {
      "from": ["title", "@id"],
      "required": true
    },
    "publishedAt": {
      "from": "date",
      "postProcess": { "method": "date", "params": "iso8601" },
      "required": true
    },
    "description": {
      "from": "description"
    },
    "tags": {
      "from": "octothorpes",
      "postProcess": { "method": "extractTags" }
    },
    "image": {
      "from": "image"
    }
  }
}
