{
  "@context": "http://purl.org/rss/1.0/",
  "@id": "https://octothorp.es/publishers/rss2",
  "@type": "resolver",
  "schema": {
    "title": {
      "from": ["title", "@id"],
      "required": true
    },
    "link": {
      "from": "@id",
      "required": true
    },
    "guid": {
      "from": "@id"
    },
    "pubDate": {
      "from": "date",
      "postProcess": { "method": "date", "params": "rfc822" },
      "required": true
    },
    "description": {
      "from": "description"
    },
    "image": {
      "from": "image"
    }
  }
}
