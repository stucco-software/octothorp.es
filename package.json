{
	"name": "octothorp.es",
	"version": "0.6.7",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "vite dev --host 0.0.0.0",
		"build": "npm run build:components && vite build",
		"build:components": "vite build --config vite.config.components.js",
		"preview": "vite preview",
		"test": "vitest",
		"demo": "sirv demo --cors --port 8888",
		"smoketest": "node scripts/smoketest.js",
		"smoketest:full": "node scripts/smoketest.js --full",
		"smoketest:check": "node scripts/smoketest.js && vitest run src/tests/integration/smoketest.test.js",
		"smoketest:check:full": "node scripts/smoketest.js --full && vitest run src/tests/integration/smoketest.test.js",
		"smoketest:update": "node scripts/smoketest.js --update",
		"smoketest:update:full": "node scripts/smoketest.js --update --full"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"dotenv": "^17.4.2",
		"graph-rdfa-processor": "^2.0.0",
		"js-yaml": "^4.1.1",
		"jsonld-rdfa-parser": "^2.0.0",
		"sirv-cli": "^2.0.2",
		"svelte": "^4.2.7",
		"vite": "^5.0.3",
		"vitest": "^1.2.0"
	},
	"type": "module",
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"fast-xml-parser": "^5.8.0",
		"jsdom": "^24.0.0",
		"jsonld": "^8.3.2",
		"linkedom": "^0.18.12",
		"mdsvex": "^0.11.0",
		"nodemailer": "^6.9.13",
		"normalize-url": "^8.0.1"
	}
}
